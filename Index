<div id="global-tip"></div>

<script>
// ─── Config ───────────────────────────────────────────────────────────────────
var CHAT_MAX_DOM   = 75;
var CHAT_BATCH_MS  = 150;
var WS_THROTTLE_MS = 80;
var SYSLOG_MAX     = 80;
var LOW_PERF_MODE  = false;

// ─── State ────────────────────────────────────────────────────────────────────
var ws, settings = {}, chatCount = 0, clipCount = 0, reconnectTimer;
var chatQueue = [], chatFlushTimer = null;
var lastWsProcess = 0, wsQueue = [], wsFlushTimer = null;
var eventTimes = {}, EVENT_COOLDOWN = 500;
var uptimeInterval = null, streamStartTs = null;
var sysLogLines = 0;

// ─── Help Modal ───────────────────────────────────────────────────────────────
function openHelp() {
  document.getElementById('helpModal').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeHelp() {
  document.getElementById('helpModal').classList.remove('open');
  document.body.style.overflow = '';
}
document.addEventListener('keydown', function(e) { if(e.key === 'Escape') closeHelp(); });

// ─── WebSocket ────────────────────────────────────────────────────────────────
function connectWS() {
  ws = new WebSocket('ws://' + location.host + '/ws');
  ws.onopen = function() {
    document.getElementById('wsDot').style.cssText = 'background:var(--green);box-shadow:0 0 12px var(--green)';
    document.getElementById('wsStatus').textContent = 'ПОДКЛЮЧЕНО';
    clearTimeout(reconnectTimer);
  };
  ws.onclose = function() {
    document.getElementById('wsDot').style.cssText = 'background:var(--red);box-shadow:0 0 8px var(--red)';
    document.getElementById('wsStatus').textContent = 'ОТКЛЮЧЕНО';
    reconnectTimer = setTimeout(connectWS, 3000);
  };
  ws.onerror = function() { document.getElementById('wsStatus').textContent = 'ОШИБКА'; };
  ws.onmessage = function(e) {
    var now = Date.now();
    try { wsQueue.push(JSON.parse(e.data)); } catch(err) { return; }
    if (now - lastWsProcess < WS_THROTTLE_MS) {
      if (!wsFlushTimer) wsFlushTimer = setTimeout(flushWsQueue, WS_THROTTLE_MS);
      return;
    }
    flushWsQueue();
  };
}

function flushWsQueue() {
  wsFlushTimer = null; lastWsProcess = Date.now();
  var msgs = wsQueue.slice(); wsQueue = [];
  if (LOW_PERF_MODE) {
    var chatMsgs = msgs.filter(function(m){return m.event==='chat_message';});
    var others = msgs.filter(function(m){return m.event!=='chat_message';});
    msgs = others.concat(chatMsgs.slice(-5));
  }
  msgs.forEach(function(msg){ handleEvent(msg); });
}

function handleEvent(msg) {
  switch(msg.event) {
    case 'init':
      settings = msg.settings || {};
      applySettings(settings);
      if (msg.history && msg.history.length) {
        msg.history.forEach(function(m) {
          chatQueue.push({username:m.username,message:m.message,isMod:m.is_mod,isSub:m.is_sub,isBot:false});
        });
        flushChatQueue();
      }
      // Обновляем статус IRC
      updateTwitchStatus(msg.twitch_connected);
      break;
    case 'chat_message':
      chatCount++;
      var cc=document.getElementById('chat-count'); var sc=document.getElementById('stat-chatcount');
      if(cc) cc.textContent=chatCount+' сообщений';
      if(sc) sc.textContent=chatCount;
      chatQueue.push({username:msg.username,message:msg.message,isMod:msg.is_mod,isSub:msg.is_sub,isBot:false});
      scheduleChatFlush();
      break;
    case 'bot_message':
      chatQueue.push({username:'🤖 BOT',message:msg.message,isMod:false,isSub:false,isBot:true});
      scheduleChatFlush();
      break;
    case 'moderation_action':
      if(throttleEvent('mod')){ sysLog('🛡 '+msg.username+': '+msg.reason); notify('🛡 Мод: '+msg.username); }
      break;
    case 'clip_created':
      clipCount++;
      var sc2=document.getElementById('stat-clips'); if(sc2) sc2.textContent=clipCount;
      sysLog('🎬 Клип: '+msg.label); notify('🎬 '+msg.label);
      break;
    case 'stream_started':
      document.getElementById('streamDot').classList.add('live');
      document.getElementById('streamStatus').textContent='СТРИМ LIVE';
      streamStartTs=msg.ts*1000; startUptimeTicker();
      notify('▶️ Стрим начат!');
      break;
    case 'stream_stopped':
      document.getElementById('streamDot').classList.remove('live');
      document.getElementById('streamStatus').textContent='СТРИМ ОФЛАЙН';
      streamStartTs=null; stopUptimeTicker();
      break;
    case 'death_updated':
      var d1=document.getElementById('stat-deaths'); var d2=document.getElementById('death-count-big');
      if(d1) d1.textContent=msg.count; if(d2) d2.textContent=msg.count;
      break;
    case 'goal_updated':
      updateGoalDisplay(msg.current, parseInt(settings.goal_target||100), settings.goal_label||'Цель');
      break;
    case 'twitch_connected':
      updateTwitchStatus(true);
      sysLog('✅ Twitch IRC подключён: #'+msg.channel);
      notify('✅ Бот подключён к Twitch!');
      break;
    case 'twitch_disconnected':
      updateTwitchStatus(false);
      sysLog('❌ Twitch IRC отключён');
      break;
    case 'timeout_user': if(throttleEvent('timeout')) notify('🔇 Тайм-аут: '+msg.username); break;
    case 'ban_user': notify('🔨 Бан: '+msg.username); break;
    case 'event_follow': sysLog('❤️ Follow: '+msg.username); notify('❤️ Фоллоу: '+msg.username); break;
    case 'event_sub': sysLog('🎉 Sub: '+msg.username); notify('🎉 Саб: '+msg.username); break;
    case 'event_giftsub': sysLog('🎁 Gift: '+msg.gifter+' ×'+msg.count); notify('🎁 Gift: '+msg.gifter); break;
    case 'event_raid': sysLog('🚨 Raid: '+msg.raider+' ×'+msg.viewers); notify('🚨 РЕЙД: '+msg.raider); break;
    case 'event_bits': sysLog('💎 Bits: '+msg.username+' ×'+msg.amount); notify('💎 Bits: '+msg.username); break;
    case 'event_milestone': sysLog('🏆 Milestone: '+msg.count); notify('🏆 '+msg.count+' фолловеров!'); break;
    case 'event_firstmsg': sysLog('👋 Первое: '+msg.username); break;
    case 'event_return': sysLog('🎊 Вернулся: '+msg.username); break;
  }
}

function updateTwitchStatus(connected) {
  var dot = document.getElementById('twitch-dot');
  var txt = document.getElementById('twitch-status-text');
  if (!dot) return;
  if (connected) {
    dot.style.cssText = 'background:var(--green);box-shadow:0 0 12px var(--green)';
    if (txt) txt.textContent = 'Подключён к Twitch IRC ✅';
  } else {
    dot.style.cssText = 'background:var(--red);box-shadow:0 0 8px var(--red)';
    if (txt) txt.textContent = 'Не подключён к Twitch IRC';
  }
}

function throttleEvent(type) {
  var now=Date.now();
  if(now-(eventTimes[type]||0)<EVENT_COOLDOWN) return false;
  eventTimes[type]=now; return true;
}

// ─── Chat batching ────────────────────────────────────────────────────────────
function scheduleChatFlush() { if(!chatFlushTimer) chatFlushTimer=setTimeout(flushChatQueue,CHAT_BATCH_MS); }

function flushChatQueue() {
  chatFlushTimer=null;
  if(!chatQueue.length) return;
  var msgs=chatQueue.slice(); chatQueue=[];
  var el=document.getElementById('chat-messages');
  var elM=document.getElementById('chat-messages-mobile');
  if(!el) return;
  var frag=document.createDocumentFragment();
  var fragM=elM?document.createDocumentFragment():null;
  msgs.forEach(function(m){ frag.appendChild(makeChatNode(m)); if(fragM) fragM.appendChild(makeChatNode(m)); });
  el.appendChild(frag);
  if(elM&&fragM) elM.appendChild(fragM);
  while(el.children.length>CHAT_MAX_DOM) el.removeChild(el.firstChild);
  if(elM) while(elM.children.length>CHAT_MAX_DOM) elM.removeChild(elM.firstChild);
  var atBottom=el.scrollHeight-el.scrollTop-el.clientHeight<60;
  if(atBottom) el.scrollTop=el.scrollHeight;
  if(elM){var atBottomM=elM.scrollHeight-elM.scrollTop-elM.clientHeight<60; if(atBottomM) elM.scrollTop=elM.scrollHeight;}
}

function makeChatNode(m) {
  var div=document.createElement('div');
  div.className=m.isBot?'chat-msg bot-msg':'chat-msg';
  var userClass=m.isBot?'bot-user':(m.isMod?'mod-user':(m.isSub?'sub-user':''));
  var userSpan=document.createElement('span');
  userSpan.className='msg-user '+userClass;
  userSpan.textContent=m.username+(m.isMod&&!m.isBot?'🔧':'');
  var textSpan=document.createElement('span');
  textSpan.className='msg-text';
  textSpan.textContent=' '+m.message;
  div.appendChild(userSpan); div.appendChild(textSpan);
  return div;
}

function escHtml(s) { var d=document.createElement('div'); d.textContent=String(s); return d.innerHTML; }

// ─── Uptime ticker ────────────────────────────────────────────────────────────
function startUptimeTicker() {
  stopUptimeTicker();
  uptimeInterval=setInterval(function(){
    if(!streamStartTs) return;
    var elapsed=Math.floor((Date.now()-streamStartTs)/1000);
    var h=Math.floor(elapsed/3600); var m=Math.floor((elapsed%3600)/60);
    var el=document.getElementById('stat-uptime'); if(el) el.textContent=h+'ч '+m+'м';
  },60000);
}
function stopUptimeTicker() { if(uptimeInterval){clearInterval(uptimeInterval);uptimeInterval=null;} }

// ─── sysLog ───────────────────────────────────────────────────────────────────
function sysLog(text) {
  var el=document.getElementById('sys-log'); if(!el) return;
  while(sysLogLines>=SYSLOG_MAX&&el.firstChild){el.removeChild(el.firstChild);sysLogLines--;}
  var line=document.createElement('div');
  var now=new Date();
  var t=('0'+now.getHours()).slice(-2)+':'+('0'+now.getMinutes()).slice(-2)+':'+('0'+now.getSeconds()).slice(-2);
  line.innerHTML='<span style="color:var(--text3)">['+t+']</span> '+escHtml(text);
  el.appendChild(line); sysLogLines++; el.scrollTop=el.scrollHeight;
}

// ─── Low perf ─────────────────────────────────────────────────────────────────
function setLowPerfMode(on) {
  LOW_PERF_MODE=on;
  if(on){CHAT_BATCH_MS=500;WS_THROTTLE_MS=300;CHAT_MAX_DOM=30;document.body.classList.add('low-perf');}
  else{CHAT_BATCH_MS=150;WS_THROTTLE_MS=80;CHAT_MAX_DOM=75;document.body.classList.remove('low-perf');}
  saveSetting('low_perf_mode',on?'1':'0');
  notify(on?'⚡ Режим низкой нагрузки ВКЛЮЧЁН':'✅ Обычный режим');
}

// ─── Settings ─────────────────────────────────────────────────────────────────
function applySettings(s) {
  ['twitch_channel','twitch_token','bot_username','tg_link','tiktok_link','discord_link','youtube_link',
   'points_per_message','points_per_minute','autopost_interval','clip_duration',
   'caps_threshold','spam_threshold','banned_words','goal_label','goal_current','goal_target',
   'msg_follow','msg_sub','msg_resub','msg_giftsub','msg_raid','msg_bits',
   'msg_firstmsg','msg_return','msg_stream_hello','msg_stream_bye','msg_milestone',
   'milestones','return_days','event_delay','follower_count'].forEach(function(k){
    var el=document.getElementById(k); if(el&&s[k]!==undefined) el.value=s[k];
  });
  ['feat_points','feat_minigames','feat_moderation','feat_clips','feat_autopost','feat_commands',
   'feat_trivia','feat_roulette','feat_heist','feat_vip','feat_deaths','feat_goals','feat_followage','feat_tts',
   'feat_events','mod_links','mod_caps','mod_spam','mod_repeat',
   'evt_follow','evt_sub','evt_giftsub','evt_raid','evt_bits',
   'evt_firstmsg','evt_return','evt_milestone','evt_stream_hello','evt_stream_bye'].forEach(function(k){
    var el=document.getElementById(k); if(el&&s[k]!==undefined) el.checked=s[k]==='1';
  });
  var cur=parseInt(s.goal_current||0); var tgt=parseInt(s.goal_target||100); var lbl=s.goal_label||'Цель';
  updateGoalDisplay(cur,tgt,lbl);
  var dc=parseInt(s.death_count||0);
  document.getElementById('stat-deaths').textContent=dc;
  document.getElementById('death-count-big').textContent=dc;
  syncVipCostDisplay(s);
}

function updateGoalDisplay(cur,tgt,lbl) {
  var pct=tgt?Math.min(100,Math.round(cur/tgt*100)):0;
  ['goal-label-display','goal-preview-label'].forEach(function(id){var el=document.getElementById(id);if(el)el.textContent=lbl+': '+cur+'/'+tgt;});
  ['goal-progress','goal-preview-bar'].forEach(function(id){var el=document.getElementById(id);if(el)el.style.width=pct+'%';});
  document.getElementById('goal-current-display').textContent=cur;
  document.getElementById('goal-pct-display').textContent=pct+'%';
  document.getElementById('goal-target-display').textContent=tgt;
  document.getElementById('goal-preview-cur').textContent=cur;
  document.getElementById('goal-preview-pct').textContent=pct+'%';
  document.getElementById('goal-preview-tgt').textContent=tgt;
}

async function saveSetting(key,value) {
  await fetch('/api/settings',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({settings:{[key]:value}})});
  settings[key]=value;
}
function saveFeat(key,checkbox) {
  saveSetting(key,checkbox.checked?'1':'0');
  sysLog((checkbox.checked?'✅ Включено: ':'❌ Выключено: ')+key);
}
async function saveAllSettings() {
  var s={};
  ['twitch_channel','twitch_token','bot_username','tg_link','tiktok_link','discord_link','youtube_link',
   'points_per_message','points_per_minute','autopost_interval','clip_duration',
   'caps_threshold','spam_threshold','banned_words','goal_label','goal_current','goal_target'].forEach(function(k){
    var el=document.getElementById(k); if(el) s[k]=el.value;
  });
  await fetch('/api/settings',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({settings:s})});
  notify('💾 Настройки сохранены!'); sysLog('💾 Все настройки сохранены');
}
async function saveLinks() { await saveAllSettings(); }
async function saveConnectionSettings() { await saveAllSettings(); }
async function saveModerationSettings() { await saveAllSettings(); }

// ─── Stream ───────────────────────────────────────────────────────────────────
async function startStream() { await fetch('/api/stream/start',{method:'POST'}); loadStats(); }
async function stopStream() { await fetch('/api/stream/stop',{method:'POST'}); }

// ─── Stats ────────────────────────────────────────────────────────────────────
async function loadStats() {
  var r=await fetch('/api/stats'); var data=await r.json();
  document.getElementById('stat-uptime').textContent=data.uptime||' - ';
  document.getElementById('stat-chatcount').textContent=data.stream_chat_count||0;
  document.getElementById('stat-deaths').textContent=data.death_count;
  document.getElementById('death-count-big').textContent=data.death_count;
  var tbody=document.getElementById('top-points-body');
  var lb=document.getElementById('leaderboard-body');
  if(data.top_points.length){
    var rows=data.top_points.map(function(r,i){return '<tr><td class="rank">#'+(i+1)+'</td><td>'+escHtml(r.username)+'</td><td class="pts">'+r.points+'</td></tr>';}).join('');
    tbody.innerHTML=rows; lb.innerHTML=rows;
  }
  clipCount=data.clips.length; document.getElementById('stat-clips').textContent=clipCount;
  updateGoalDisplay(data.goal_current,data.goal_target,data.goal_label);
  if(data.stream_active){document.getElementById('streamDot').classList.add('live');document.getElementById('streamStatus').textContent='СТРИМ LIVE';}
  updateTwitchStatus(data.twitch_connected);
  refreshClips(data.clips);
}

function refreshClips(clips) {
  var el=document.getElementById('clips-list');
  if(!clips||!clips.length){el.innerHTML='<p style="color:var(--text3);font-size:12px;text-align:center;padding:20px">Нет клипов</p>';return;}
  el.innerHTML=clips.map(function(c){
    var d=new Date(c.ts*1000); var time=d.toLocaleTimeString('ru-RU',{hour:'2-digit',minute:'2-digit'});
    return '<div class="clip-item"><div><div class="clip-label">🎬 '+escHtml(c.label)+'</div><div class="clip-meta">'+time+' · '+c.duration+' мин</div></div></div>';
  }).join('');
}

// ─── Actions ──────────────────────────────────────────────────────────────────
async function testChat() {
  var user=document.getElementById('test-user').value||'viewer1';
  var msg=document.getElementById('test-msg').value;
  var isMod=document.getElementById('test-mod').checked;
  if(!msg) return;
  await fetch('/api/chat/simulate?username='+encodeURIComponent(user)+'&message='+encodeURIComponent(msg)+'&is_mod='+isMod,{method:'POST'});
  document.getElementById('test-msg').value='';
}
async function broadcastMsg() {
  var inp=document.getElementById('broadcast-msg');if(!inp||!inp.value.trim())inp=document.getElementById('chat-send-input');
  var msg=inp.value.trim(); if(!msg) return;
  await fetch('/api/chat/broadcast?message='+encodeURIComponent(msg),{method:'POST'});
  inp.value='';
}
async function createClip() {
  var label=document.getElementById('clip-label').value||'Ручной клип';
  await fetch('/api/clip?label='+encodeURIComponent(label),{method:'POST'});
  document.getElementById('clip-label').value='';
}
async function incrementDeath() {
  var r=await fetch('/api/death',{method:'POST'}); var data=await r.json();
  document.getElementById('stat-deaths').textContent=data.count;
  document.getElementById('death-count-big').textContent=data.count;
}
async function resetDeath() {
  await fetch('/api/death/reset',{method:'POST'});
  document.getElementById('stat-deaths').textContent=0;
  document.getElementById('death-count-big').textContent=0;
  notify('💀 Счётчик смертей сброшен');
}
async function incrementGoal() {
  var inc=parseInt(document.getElementById('goal-inc').value)||1;
  var cur=parseInt(settings.goal_current||0)+inc;
  var tgt=parseInt(settings.goal_target||100); var lbl=settings.goal_label||'Цель';
  await fetch('/api/goal?current='+cur+'&target='+tgt+'&label='+encodeURIComponent(lbl),{method:'POST'});
  settings.goal_current=String(cur); updateGoalDisplay(cur,tgt,lbl);
}
async function updateGoal() {
  var cur=parseInt(document.getElementById('goal_current').value)||0;
  var tgt=parseInt(document.getElementById('goal_target').value)||100;
  var lbl=document.getElementById('goal_label').value||'Цель';
  await fetch('/api/goal?current='+cur+'&target='+tgt+'&label='+encodeURIComponent(lbl),{method:'POST'});
  settings.goal_current=String(cur); settings.goal_target=String(tgt); settings.goal_label=lbl;
  updateGoalDisplay(cur,tgt,lbl); notify('🎯 Цель обновлена!');
}
async function managePoints(action) {
  var user=document.getElementById('pts-username').value;
  var amount=parseInt(document.getElementById('pts-amount').value)||0;
  if(!user||!amount) return;
