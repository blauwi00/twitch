// ─── Global Tooltip ───────────────────────────────────────────────────────────
(function() {
  var tip = document.getElementById('global-tip');
  var current = null;
  var showTimer = null;

  document.addEventListener('mouseover', function(e) {
    var el = e.target.closest('[data-tip]');
    if (!el || el === current) return;
    current = el;
    clearTimeout(showTimer);
    showTimer = setTimeout(function() {
      tip.textContent = el.getAttribute('data-tip');
      tip.style.display = 'block';
      requestAnimationFrame(function() { tip.style.opacity = '1'; });
    }, 300);
  });

  document.addEventListener('mouseout', function(e) {
    var el = e.target.closest('[data-tip]');
    if (!el) return;
    var to = e.relatedTarget;
    if (to && el.contains(to)) return;
    current = null;
    clearTimeout(showTimer);
    tip.style.opacity = '0';
    setTimeout(function() { if (tip.style.opacity === '0') tip.style.display = 'none'; }, 150);
  });

  document.addEventListener('mousemove', function(e) {
    if (!current) return;
    var x = e.clientX;
    var y = e.clientY;
    var tw = tip.offsetWidth;
    var th = tip.offsetHeight;
    var vw = window.innerWidth;
    var vh = window.innerHeight;

    // По умолчанию  -  над курсором
    var left = x - tw / 2;
    var top  = y - th - 12;

    // Не уходить за правый край
    if (left + tw > vw - 8) left = vw - tw - 8;
    // Не уходить за левый край
    if (left < 8) left = 8;
    // Если не влезает сверху  -  показать снизу
    if (top < 8) top = y + 16;
    // Не уходить за нижний край
    if (top + th > vh - 8) top = y - th - 12;

    tip.style.left = left + 'px';
    tip.style.top  = top  + 'px';
  });
})();

