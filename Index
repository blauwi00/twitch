<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TWITCH BOT PANEL</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Unbounded:wght@400;700;900&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0a0f;
    --bg2: #111118;
    --bg3: #1a1a24;
    --border: #2a2a3a;
    --accent: #7c3aed;
    --accent2: #a855f7;
    --accent3: #c084fc;
    --green: #22c55e;
    --red: #ef4444;
    --yellow: #eab308;
    --cyan: #06b6d4;
    --text: #e2e8f0;
    --text2: #94a3b8;
    --text3: #475569;
    --glow: 0 0 20px rgba(124, 58, 237, 0.4);
    --glow2: 0 0 40px rgba(124, 58, 237, 0.2);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Space Mono', monospace;
    min-height: 100vh;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 9999;
    opacity: 0.4;
  }

  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(124,58,237,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(124,58,237,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  .layout {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 260px 1fr 320px;
    grid-template-rows: 60px 1fr;
    min-height: 100vh;
  }

  @media (max-width: 900px) {
    .layout { grid-template-columns: 1fr; grid-template-rows: auto auto 1fr; }
    .sidebar { display: none; grid-column: 1; grid-row: 2; border-right: none; border-bottom: 1px solid var(--border); max-height: 60vh; overflow-y: auto; }
    .sidebar.open { display: flex; }
    .main { grid-column: 1; grid-row: 3; padding: 12px; }
    .chat-panel { display: none; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .form-row { grid-template-columns: 1fr; }
    .features-grid { grid-template-columns: 1fr; }
    .mobile-menu-btn { display: flex !important; }
    .mobile-chat-btn { display: flex !important; }
    .status-text { display: none; }
    .stream-controls { gap: 4px; }
    .stream-controls .btn { padding: 5px 8px; font-size: 9px; }
    header { padding: 0 12px; gap: 8px; }
    .header-status { gap: 8px; }
    .logo { font-size: 12px; }
    .stat-value { font-size: 18px; }
    .death-number { font-size: 48px; }
    .modal { width: 96%; max-height: 90vh; }
    .cmd-row { grid-template-columns: 140px 1fr auto; gap: 8px; }
  }

  @media (max-width: 480px) {
    .stats-grid { grid-template-columns: 1fr 1fr; gap: 8px; }
    .stream-controls .btn-sm { padding: 5px 6px; font-size: 9px; }
    header { padding: 0 8px; }
    .main { padding: 10px; }
    .card { padding: 14px; }
    .cmd-row { grid-template-columns: 1fr; gap: 4px; }
    .flex-wrap { flex-direction: column; }
  }

  .mobile-menu-btn, .mobile-chat-btn {
    display: none; align-items: center; justify-content: center;
    width: 36px; height: 36px; background: var(--bg3);
    border: 1px solid var(--border); border-radius: 6px;
    cursor: pointer; font-size: 16px; color: var(--text2); flex-shrink: 0;
  }

  /* ── HEADER ── */
  header {
    grid-column: 1 / -1;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 24px; background: var(--bg2);
    border-bottom: 1px solid var(--border);
    position: relative; overflow: hidden;
  }
  header::after {
    content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent), var(--accent2), transparent);
  }
  .logo {
    font-family: 'Unbounded', sans-serif; font-weight: 900; font-size: 16px;
    letter-spacing: 0.15em;
    background: linear-gradient(135deg, var(--accent2), var(--cyan));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .header-status { display: flex; align-items: center; gap: 20px; }
  .status-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--red); box-shadow: 0 0 8px var(--red); transition: all 0.3s;
  }
  .status-dot.live { background: var(--green); box-shadow: 0 0 12px var(--green); animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.7;transform:scale(1.3)} }
  .status-text { font-size: 11px; letter-spacing: 0.1em; color: var(--text2); }
  .stream-controls { display: flex; gap: 8px; }

  /* ── SIDEBAR ── */
  .sidebar {
    background: var(--bg2); border-right: 1px solid var(--border);
    overflow-y: auto; padding: 16px;
    display: flex; flex-direction: column; gap: 4px;
  }
  .nav-section {
    font-size: 9px; letter-spacing: 0.2em; color: var(--text3);
    text-transform: uppercase; padding: 16px 8px 6px;
    font-family: 'Unbounded', sans-serif;
  }
  .nav-item {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 12px; border-radius: 6px; cursor: pointer;
    font-size: 12px; color: var(--text2); transition: all 0.15s;
    border: 1px solid transparent; user-select: none;
  }
  .nav-item:hover { background: var(--bg3); color: var(--text); border-color: var(--border); }
  .nav-item.active { background: rgba(124,58,237,0.15); color: var(--accent3); border-color: rgba(124,58,237,0.3); box-shadow: var(--glow2); }
  .nav-icon { font-size: 14px; width: 18px; text-align: center; }

  /* ── MAIN ── */
  .main { overflow-y: auto; padding: 24px; display: flex; flex-direction: column; gap: 20px; }
  .tab-content { display: none; }
  .tab-content.active { display: flex; flex-direction: column; gap: 20px; }

  /* ── TAB DESCRIPTION BANNER ── */
  .tab-desc {
    background: linear-gradient(135deg, rgba(124,58,237,0.08), rgba(6,182,212,0.06));
    border: 1px solid rgba(124,58,237,0.2);
    border-radius: 10px;
    padding: 14px 18px;
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }
  .tab-desc-icon { font-size: 22px; flex-shrink: 0; margin-top: 1px; }
  .tab-desc-title {
    font-family: 'Unbounded', sans-serif;
    font-size: 11px;
    font-weight: 700;
    color: var(--accent3);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .tab-desc-text { font-size: 11px; color: var(--text2); line-height: 1.7; }
  .tab-desc-text b { color: var(--accent3); }

  .section-title {
    font-family: 'Unbounded', sans-serif; font-size: 13px; font-weight: 700;
    color: var(--accent3); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 2px;
  }

  .card {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: 10px; padding: 20px; position: relative; overflow: hidden;
  }
  .card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, var(--accent), var(--accent2));
    opacity: 0; transition: opacity 0.3s;
  }
  .card:hover::before { opacity: 1; }
  .card-title {
    font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--text3); font-family: 'Unbounded', sans-serif; margin-bottom: 14px;
  }

  /* ── FEATURES GRID ── */
  .features-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px; }
  .feature-toggle {
    display: flex; align-items: center; justify-content: space-between;
    background: var(--bg3); border: 1px solid var(--border);
    border-radius: 8px; padding: 12px 14px; transition: all 0.2s;
  }
  .feature-toggle:hover { border-color: rgba(124,58,237,0.4); }
  .feature-label { display: flex; align-items: center; gap: 10px; font-size: 12px; color: var(--text2); }
  .feature-icon { font-size: 16px; }

  /* ── TOGGLE ── */
  .toggle { position: relative; width: 40px; height: 22px; flex-shrink: 0; }
  .toggle input { opacity: 0; width: 0; height: 0; }
  .toggle-slider {
    position: absolute; inset: 0; background: var(--bg);
    border: 1px solid var(--border); border-radius: 22px; cursor: pointer; transition: all 0.3s;
  }
  .toggle-slider::after {
    content: ''; position: absolute; width: 14px; height: 14px;
    left: 3px; top: 3px; background: var(--text3); border-radius: 50%; transition: all 0.3s;
  }
  .toggle input:checked + .toggle-slider { background: rgba(124,58,237,0.3); border-color: var(--accent); box-shadow: 0 0 10px rgba(124,58,237,0.4); }
  .toggle input:checked + .toggle-slider::after { transform: translateX(18px); background: var(--accent2); }

  /* ── BUTTONS ── */
  .btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 9px 18px; border-radius: 6px; border: none; cursor: pointer;
    font-family: 'Space Mono', monospace; font-size: 11px; font-weight: 700;
    letter-spacing: 0.08em; transition: all 0.2s; text-transform: uppercase;
    position: relative;
  }
  .btn-primary { background: var(--accent); color: white; box-shadow: 0 0 15px rgba(124,58,237,0.4); }
  .btn-primary:hover { background: var(--accent2); box-shadow: 0 0 25px rgba(124,58,237,0.6); transform: translateY(-1px); }
  .btn-danger { background: rgba(239,68,68,0.2); color: var(--red); border: 1px solid rgba(239,68,68,0.3); }
  .btn-danger:hover { background: rgba(239,68,68,0.3); box-shadow: 0 0 15px rgba(239,68,68,0.3); }
  .btn-success { background: rgba(34,197,94,0.2); color: var(--green); border: 1px solid rgba(34,197,94,0.3); }
  .btn-success:hover { background: rgba(34,197,94,0.3); }
  .btn-ghost { background: var(--bg3); color: var(--text2); border: 1px solid var(--border); }
  .btn-ghost:hover { border-color: var(--accent); color: var(--accent3); }
  .btn-sm { padding: 6px 12px; font-size: 10px; }

  /* ── TOOLTIP  -  глобальный через JS ── */
  #global-tip {
    position: fixed;
    background: #1e1e2e;
    border: 1px solid var(--accent);
    color: var(--text);
    font-size: 10px;
    font-family: 'Space Mono', monospace;
    line-height: 1.6;
    padding: 6px 10px;
    border-radius: 6px;
    max-width: 220px;
    text-align: center;
    pointer-events: none;
    z-index: 99999;
    box-shadow: 0 4px 20px rgba(124,58,237,0.3);
    white-space: normal;
    display: none;
    transition: opacity 0.15s;
    opacity: 0;
  }

  /* ── INPUTS ── */
  .form-group { display: flex; flex-direction: column; gap: 6px; margin-bottom: 14px; }
  .form-label { font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text3); font-family: 'Unbounded', sans-serif; }
  .form-input, .form-select {
    background: var(--bg3); border: 1px solid var(--border); border-radius: 6px;
    padding: 9px 12px; color: var(--text); font-family: 'Space Mono', monospace;
    font-size: 12px; transition: all 0.2s; outline: none; width: 100%;
  }
  .form-input:focus, .form-select:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(124,58,237,0.15); }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }

  /* ── STATS ── */
  .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 4px; }
  .stat-card {
    background: var(--bg3); border: 1px solid var(--border); border-radius: 8px;
    padding: 16px; text-align: center; position: relative; overflow: hidden; transition: all 0.2s;
  }
  .stat-card:hover { border-color: var(--accent); box-shadow: var(--glow2); transform: translateY(-2px); }
  .stat-value { font-family: 'Unbounded', sans-serif; font-size: 24px; font-weight: 900; color: var(--accent3); display: block; line-height: 1; margin-bottom: 6px; }
  .stat-label { font-size: 10px; color: var(--text3); letter-spacing: 0.1em; text-transform: uppercase; font-family: 'Unbounded', sans-serif; }

  /* ── CHAT PANEL ── */
  .chat-panel {
    background: var(--bg2); border-left: 1px solid var(--border);
    display: flex; flex-direction: column;
    height: calc(100vh - 60px); position: sticky; top: 0;
  }
  .chat-header {
    padding: 14px 16px; border-bottom: 1px solid var(--border);
    font-family: 'Unbounded', sans-serif; font-size: 11px; letter-spacing: 0.12em; color: var(--text2);
    display: flex; align-items: center; justify-content: space-between;
  }
  .chat-messages { flex: 1; overflow-y: auto; padding: 12px; display: flex; flex-direction: column; gap: 4px; }
  .chat-messages::-webkit-scrollbar { width: 4px; }
  .chat-messages::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }
  .chat-msg { padding: 6px 10px; border-radius: 6px; font-size: 12px; line-height: 1.5; transition: background 0.2s; border-left: 2px solid transparent; }
  .chat-msg:hover { background: var(--bg3); }
  .chat-msg.bot-msg { border-left-color: var(--accent); background: rgba(124,58,237,0.08); }
  .msg-user { font-weight: 700; font-size: 11px; color: var(--accent3); margin-right: 6px; }
  .msg-user.bot-user { color: var(--cyan); }
  .msg-user.mod-user { color: var(--yellow); }
  .msg-user.sub-user { color: var(--green); }
  .msg-text { color: var(--text2); }
  .chat-input-area { padding: 12px; border-top: 1px solid var(--border); display: flex; gap: 8px; }
  .chat-input { flex: 1; background: var(--bg3); border: 1px solid var(--border); border-radius: 6px; padding: 8px 12px; color: var(--text); font-family: 'Space Mono', monospace; font-size: 12px; outline: none; transition: border-color 0.2s; }
  .chat-input:focus { border-color: var(--accent); }

  /* ── TABLE ── */
  .table { width: 100%; border-collapse: collapse; font-size: 12px; }
  .table th { text-align: left; padding: 8px 12px; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text3); font-family: 'Unbounded', sans-serif; border-bottom: 1px solid var(--border); }
  .table td { padding: 10px 12px; border-bottom: 1px solid rgba(42,42,58,0.5); color: var(--text2); }
  .table tr:hover td { background: var(--bg3); }
  .table .rank { color: var(--accent3); font-weight: 700; font-family: 'Unbounded', sans-serif; }
  .table .pts { color: var(--yellow); font-weight: 700; }

  /* ── PROGRESS BAR ── */
  .progress-bar { width: 100%; height: 8px; background: var(--bg3); border-radius: 4px; overflow: hidden; margin: 8px 0; }
  .progress-fill { height: 100%; background: linear-gradient(90deg, var(--accent), var(--accent2)); border-radius: 4px; transition: width 0.5s ease; box-shadow: 0 0 10px rgba(124,58,237,0.5); }

  /* ── CLIPS ── */
  .clip-item { display: flex; align-items: center; justify-content: space-between; background: var(--bg3); border: 1px solid var(--border); border-radius: 8px; padding: 12px 14px; margin-bottom: 8px; transition: all 0.2s; }
  .clip-item:hover { border-color: var(--accent); }
  .clip-label { font-size: 13px; color: var(--text); }
  .clip-meta { font-size: 10px; color: var(--text3); margin-top: 2px; }

  /* ── NOTIFICATIONS ── */
  .notifications { position: fixed; top: 70px; right: 16px; z-index: 1000; display: flex; flex-direction: column; gap: 8px; pointer-events: none; }
  .notif { background: var(--bg2); border: 1px solid var(--accent); border-radius: 8px; padding: 12px 16px; font-size: 12px; max-width: 280px; box-shadow: var(--glow); animation: slideIn 0.3s ease, fadeOut 0.3s ease 2.7s forwards; }
  @keyframes slideIn { from{transform:translateX(100%);opacity:0} to{transform:translateX(0);opacity:1} }
  @keyframes fadeOut { to{opacity:0;transform:translateX(20px)} }

  /* ── DEATH COUNTER ── */
  .death-display { text-align: center; padding: 20px; }
  .death-number { font-family: 'Unbounded', sans-serif; font-size: 64px; font-weight: 900; color: var(--red); text-shadow: 0 0 30px rgba(239,68,68,0.5); line-height: 1; display: block; margin-bottom: 8px; }

  /* ── GOAL ── */
  .goal-section { padding: 4px 0; }
  .goal-label-text { font-family: 'Unbounded', sans-serif; font-size: 12px; margin-bottom: 8px; color: var(--text); }
  .goal-numbers { display: flex; justify-content: space-between; font-size: 11px; color: var(--text2); margin-top: 6px; }

  /* ── BADGE ── */
  .badge { display: inline-flex; align-items: center; padding: 2px 8px; border-radius: 4px; font-size: 10px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; }
  .badge-green { background: rgba(34,197,94,0.15); color: var(--green); border: 1px solid rgba(34,197,94,0.3); }
  .badge-red { background: rgba(239,68,68,0.15); color: var(--red); border: 1px solid rgba(239,68,68,0.3); }
  .badge-purple { background: rgba(124,58,237,0.15); color: var(--accent3); border: 1px solid rgba(124,58,237,0.3); }
  .badge-cyan { background: rgba(6,182,212,0.15); color: var(--cyan); border: 1px solid rgba(6,182,212,0.3); }

  /* ── HELP MODAL ── */
  .modal-overlay {
    display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.8);
    z-index: 2000; align-items: center; justify-content: center;
    backdrop-filter: blur(4px);
  }
  .modal-overlay.open { display: flex; }
  .modal {
    background: var(--bg2); border: 1px solid var(--accent);
    border-radius: 14px; width: 90%; max-width: 800px; max-height: 85vh;
    overflow-y: auto; box-shadow: 0 0 60px rgba(124,58,237,0.3);
    animation: modalIn 0.25s ease;
  }
  @keyframes modalIn { from{transform:scale(0.95);opacity:0} to{transform:scale(1);opacity:1} }
  .modal-header {
    position: sticky; top: 0; background: var(--bg2);
    padding: 20px 24px; border-bottom: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between;
    z-index: 10;
  }
  .modal-title { font-family: 'Unbounded', sans-serif; font-size: 15px; font-weight: 900; color: var(--accent3); letter-spacing: 0.1em; }
  .modal-close { background: var(--bg3); border: 1px solid var(--border); color: var(--text2); width: 32px; height: 32px; border-radius: 6px; cursor: pointer; font-size: 16px; display: flex; align-items: center; justify-content: center; transition: all 0.2s; }
  .modal-close:hover { border-color: var(--red); color: var(--red); }
  .modal-body { padding: 24px; }

  /* ── COMMAND REFERENCE ── */
  .cmd-section { margin-bottom: 24px; }
  .cmd-section-title {
    font-family: 'Unbounded', sans-serif; font-size: 10px; font-weight: 700;
    color: var(--text3); letter-spacing: 0.2em; text-transform: uppercase;
    padding: 8px 0; border-bottom: 1px solid var(--border); margin-bottom: 12px;
  }
  .cmd-grid { display: flex; flex-direction: column; gap: 6px; }
  .cmd-row {
    display: grid; grid-template-columns: 180px 1fr auto;
    align-items: start; gap: 12px;
    background: var(--bg3); border: 1px solid var(--border);
    border-radius: 8px; padding: 10px 14px; transition: border-color 0.2s;
  }
  .cmd-row:hover { border-color: rgba(124,58,237,0.4); }
  .cmd-name { color: var(--accent3); font-weight: 700; font-size: 12px; font-family: 'Space Mono', monospace; }
  .cmd-desc { color: var(--text2); font-size: 11px; line-height: 1.6; }
  .cmd-example { font-size: 10px; color: var(--text3); margin-top: 3px; }
  .cmd-example span { color: var(--cyan); }

  /* ── HELP BTN ── */
  .help-btn {
    display: inline-flex; align-items: center; justify-content: center;
    width: 26px; height: 26px; border-radius: 50%;
    background: rgba(124,58,237,0.15); border: 1px solid rgba(124,58,237,0.3);
    color: var(--accent3); font-size: 12px; cursor: pointer;
    transition: all 0.2s; font-weight: 700; flex-shrink: 0;
  }
  .help-btn:hover { background: rgba(124,58,237,0.3); box-shadow: 0 0 12px rgba(124,58,237,0.4); }

  /* ── MISC ── */
  body.low-perf * { animation: none !important; transition: none !important; }
  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--accent); }
  .separator { height: 1px; background: var(--border); margin: 4px 0; }
  .flex { display: flex; } .gap-8 { gap: 8px; } .gap-12 { gap: 12px; }
  .items-center { align-items: center; } .justify-between { justify-content: space-between; }
  .flex-wrap { flex-wrap: wrap; } .mt-8 { margin-top: 8px; } .mt-16 { margin-top: 16px; } .mb-8 { margin-bottom: 8px; }
  .wslog { max-height: 120px; overflow-y: auto; background: var(--bg); border: 1px solid var(--border); border-radius: 6px; padding: 8px; font-size: 10px; color: var(--green); line-height: 1.8; }
  .connection-bar { display: flex; align-items: center; gap: 8px; padding: 8px 12px; background: var(--bg3); border: 1px solid var(--border); border-radius: 6px; font-size: 11px; color: var(--text2); margin-bottom: 12px; }

  /* Mobile chat overlay */
  .chat-overlay { display: none; position: fixed; inset: 0; z-index: 500; background: rgba(0,0,0,0.7); }
  .chat-overlay.open { display: block; }
  .chat-panel-mobile { position: fixed; bottom: 0; left: 0; right: 0; height: 70vh; background: var(--bg2); border-top: 1px solid var(--border); z-index: 501; display: flex; flex-direction: column; transform: translateY(100%); transition: transform 0.3s ease; }
  .chat-panel-mobile.open { transform: translateY(0); }
</style>
</head>
<body>

<!-- ── HELP MODAL ─────────────────────────────────────────────────────────── -->
<div class="modal-overlay" id="helpModal" onclick="if(event.target===this)closeHelp()">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">📖 СПРАВОЧНИК КОМАНД</div>
      <button class="modal-close" onclick="closeHelp()">✕</button>
    </div>
    <div class="modal-body">

      <div class="cmd-section">
        <div class="cmd-section-title">👥 Команды для всех зрителей</div>
        <div class="cmd-grid">
          <div class="cmd-row">
            <div><div class="cmd-name">!points</div></div>
            <div><div class="cmd-desc">Посмотреть сколько у тебя баллов</div></div>
            <div><span class="badge badge-green">Все</span></div>
          </div>
          <div class="cmd-row">
            <div><div class="cmd-name">!top</div></div>
            <div><div class="cmd-desc">Топ-5 зрителей по количеству баллов</div></div>
            <div><span class="badge badge-green">Все</span></div>
          </div>
          
          
          
          
          <div class="cmd-row">
            <div></div>
            <div><div class="cmd-desc">Русская рулетка. 1 из 6  -  потеря ставки + тайм-аут 60 сек. 5 из 6  -  выжил, +50% от ставки (бросок × 20).</div></div>
            <div><span class="badge badge-green">Все</span></div>
          </div>
          
          <div class="cmd-row">
            <div><div class="cmd-name">!vip</div></div>
            <div><div class="cmd-desc">Купить VIP-статус на 24 часа за 1000 баллов.</div></div>
            <div><span class="badge badge-green">Все</span></div>
          </div>
          <div class="cmd-row">
            <div><div class="cmd-name">!clip <b>[название]</b></div></div>
            <div>
              <div class="cmd-desc">Создать временную метку в истории клипов.</div>
              <div class="cmd-example">Пример: <span>!clip эпичный момент</span></div>
            </div>
            <div><span class="badge badge-green">Все</span></div>
          </div>
          <div class="cmd-row">
            <div><div class="cmd-name">!uptime</div></div>
            <div><div class="cmd-desc">Сколько времени идёт стрим.</div></div>
            <div><span class="badge badge-green">Все</span></div>
          </div>
          <div class="cmd-row">
            <div><div class="cmd-name">!deaths</div></div>
            <div><div class="cmd-desc">Посмотреть текущий счётчик смертей стримера.</div></div>
            <div><span class="badge badge-green">Все</span></div>
          </div>
          <div class="cmd-row">
            <div><div class="cmd-name">!goal</div></div>
            <div><div class="cmd-desc">Прогресс текущей цели стрима (подписки, донаты и т.д.)</div></div>
            <div><span class="badge badge-green">Все</span></div>
          </div>
          <div class="cmd-row">
            <div><div class="cmd-name">!tg / !tiktok / !discord</div></div>
            <div><div class="cmd-desc">Бот пишет ссылки на соцсети стримера в чат.</div></div>
            <div><span class="badge badge-green">Все</span></div>
          </div>
          <div class="cmd-row">
            <div><div class="cmd-name">!followage</div></div>
            <div><div class="cmd-desc">Посмотреть как давно ты фолловишь канал.</div></div>
            <div><span class="badge badge-green">Все</span></div>
          </div>
        </div>
      </div>

      <div class="cmd-section">
        <div class="cmd-section-title">🔧 Команды для модераторов</div>
        <div class="cmd-grid">
          <div class="cmd-row">
            <div><div class="cmd-name">!trivia</div></div>
            <div><div class="cmd-desc">Запустить викторину. Первый правильный ответ в чате получает 200 баллов.</div></div>
            <div><span class="badge badge-purple">Мод</span></div>
          </div>
          <div class="cmd-row">
            <div><div class="cmd-name">!so <b>@user</b></div></div>
            <div>
              <div class="cmd-desc">Шаутаут другому стримеру  -  бот пишет ссылку на его канал.</div>
              <div class="cmd-example">Пример: <span>!so @другойстример</span></div>
            </div>
            <div><span class="badge badge-purple">Мод</span></div>
          </div>
          <div class="cmd-row">
            <div><div class="cmd-name">!permit <b>@user</b></div></div>
            <div>
              <div class="cmd-desc">Разрешить зрителю отправить одну ссылку (не получит предупреждение от модерации).</div>
              <div class="cmd-example">Пример: <span>!permit @viewer1</span></div>
            </div>
            <div><span class="badge badge-purple">Мод</span></div>
          </div>
          <div class="cmd-row">
            <div><div class="cmd-name">!death</div></div>
            <div><div class="cmd-desc">Добавить +1 к счётчику смертей стримера.</div></div>
            <div><span class="badge badge-purple">Мод</span></div>
          </div>
          <div class="cmd-row">
            <div><div class="cmd-name">!setgoal <b>[число]</b></div></div>
            <div>
              <div class="cmd-desc">Установить текущее значение прогресса цели.</div>
              <div class="cmd-example">Пример: <span>!setgoal 42</span></div>
            </div>
            <div><span class="badge badge-purple">Мод</span></div>
          </div>
        </div>
      </div>

      <div class="cmd-section">
        <div class="cmd-section-title">🔔 Автоматические события (не команды)</div>
        <div class="cmd-grid">
          <div class="cmd-row">
            <div><div class="cmd-name">Новый фолловер</div></div>
            <div><div class="cmd-desc">Бот автоматически приветствует нового фолловера в чате.</div></div>
            <div><span class="badge badge-cyan">Авто</span></div>
          </div>
          <div class="cmd-row">
            <div><div class="cmd-name">Подписка / Ресаб</div></div>
            <div><div class="cmd-desc">Бот благодарит за подписку. +500 баллов подписчику.</div></div>
            <div><span class="badge badge-cyan">Авто</span></div>
          </div>
          <div class="cmd-row">
            <div><div class="cmd-name">Gift sub</div></div>
            <div><div class="cmd-desc">Бот благодарит за подарочные подписки. +200 баллов за каждую подписку.</div></div>
            <div><span class="badge badge-cyan">Авто</span></div>
          </div>
          <div class="cmd-row">
            <div><div class="cmd-name">Рейд</div></div>
            <div><div class="cmd-desc">Бот приветствует рейдеров. Рейдер получает баллы: кол-во зрителей × 5.</div></div>
            <div><span class="badge badge-cyan">Авто</span></div>
          </div>
          <div class="cmd-row">
            <div><div class="cmd-name">Bits / Донат</div></div>
            <div><div class="cmd-desc">Бот благодарит за bits. +баллы: кол-во bits ÷ 10.</div></div>
            <div><span class="badge badge-cyan">Авто</span></div>
          </div>
          <div class="cmd-row">
            <div><div class="cmd-name">Первое сообщение</div></div>
            <div><div class="cmd-desc">Бот приветствует зрителя который впервые написал в чат.</div></div>
            <div><span class="badge badge-cyan">Авто</span></div>
          </div>
          <div class="cmd-row">
            <div><div class="cmd-name">Возвращение</div></div>
            <div><div class="cmd-desc">Если зритель не писал N дней (настраивается)  -  бот радуется его возвращению.</div></div>
            <div><span class="badge badge-cyan">Авто</span></div>
          </div>
        </div>
      </div>

      <div class="cmd-section">
        <div class="cmd-section-title">⚙️ Система баллов</div>
        <div style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:14px 16px;font-size:11px;color:var(--text2);line-height:2">
          💬 За каждое сообщение в чате → <b style="color:var(--yellow)">+5 баллов</b> (настраивается)<br>
          👁 За каждую минуту просмотра → <b style="color:var(--yellow)">+1 балл</b> (настраивается)<br>
          🎉 За подписку (sub) → <b style="color:var(--yellow)">+500 баллов</b><br>
          🎁 За подаренную подписку (gift sub) → <b style="color:var(--yellow)">+200 баллов</b> за каждую<br>
          🚨 За рейд → <b style="color:var(--yellow)">+5 баллов × кол-во зрителей</b><br>
          💎 За bits → <b style="color:var(--yellow)">+1 балл за каждые 10 bits</b>
        </div>
      </div>

      <div class="cmd-section">
        <div class="cmd-section-title">🛡 Система модерации</div>
        <div style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:14px 16px;font-size:11px;color:var(--text2);line-height:2">
          ⚠️ <b>1 предупреждение</b> → сообщение об ошибке в чат<br>
          🔇 <b>2 предупреждения</b> → тайм-аут 5 минут<br>
          🔨 <b>3+ предупреждений</b> → бан<br>
          <br>
          Что триггерит: ссылки без разрешения, слишком много капса (≥70%), спам одинаковыми сообщениями, забаненные слова.<br>
          Модераторы освобождены от всех ограничений.
        </div>
      </div>

    </div>
  </div>
</div>

<div class="layout">

  <!-- HEADER -->
  <header>
    <div style="display:flex;align-items:center;gap:10px">
      <div class="mobile-menu-btn" onclick="toggleSidebar()" title="Меню">☰</div>
      <div class="logo">⚡ TWITCH BOT</div>
    </div>
    <div class="header-status">
      <div class="flex items-center gap-8">
        <div class="status-dot" id="streamDot"></div>
        <span class="status-text" id="streamStatus">СТРИМ ОФЛАЙН</span>
      </div>
      <div class="flex items-center gap-8">
        <div class="status-dot" id="wsDot" style="background:var(--yellow);box-shadow:0 0 8px var(--yellow)"></div>
        <span class="status-text" id="wsStatus">ПОДКЛЮЧЕНИЕ...</span>
      </div>
      <div class="stream-controls flex gap-8">
        <button class="btn btn-success btn-sm" onclick="startStream()"
          data-tip="Запустить стрим: начать отсчёт аптайма, начислять баллы за просмотр, отправить приветствие в чат">▶ СТАРТ</button>
        <button class="btn btn-danger btn-sm" onclick="stopStream()"
          data-tip="Остановить стрим: отправить прощание в чат, сбросить аптайм">■ СТОП</button>
        <button class="btn btn-ghost btn-sm" id="lowPerfBtn" onclick="toggleLowPerf()"
          data-tip="Режим низкой нагрузки: уменьшает анимации и частоту обновлений. Включи если лагает.">⚡ LOW</button>
        <button class="btn btn-ghost btn-sm" onclick="openHelp()"
          data-tip="Справочник всех команд бота с примерами">? ПОМОЩЬ</button>
      </div>
      <div class="mobile-chat-btn" onclick="toggleChat()">💬</div>
    </div>
  </header>

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <div class="nav-section">Основное</div>
    <div class="nav-item active" onclick="showTab('dashboard', this)"
      data-tip="Общая статистика, топ баллов, прогресс цели">
      <span class="nav-icon">📊</span> Dashboard
    </div>
    <div class="nav-item" onclick="showTab('chat', this)"
      data-tip="Тест команд без Twitch, список всех команд, ручная отправка сообщений">
      <span class="nav-icon">💬</span> Чат & Команды
    </div>
    <div class="nav-item" onclick="showTab('points', this)"
      data-tip="Настройки начисления баллов, управление балансом зрителей, таблица лидеров">
      <span class="nav-icon">💰</span> Баллы
    </div>
    <div class="nav-item" onclick="showTab('moderation', this)"
      data-tip="Блокировка ссылок, капса, спама. Забаненные слова. Управление варнами.">
      <span class="nav-icon">🛡</span> Модерация
    </div>
    <div class="nav-section">Контент</div>
    <div class="nav-item" onclick="showTab('events', this)"
      data-tip="Автоответы на фолловы, сабы, рейды, bits. Настройка текстов и задержек.">
      <span class="nav-icon">🔔</span> События
    </div>

    <div class="nav-item" onclick="showTab('autopost', this)"
      data-tip="Автоматическая публикация ссылок на соцсети через заданный интервал">
      <span class="nav-icon">📣</span> Автопост
    </div>

    <div class="nav-item" onclick="showTab('commands', this)"
      data-tip="Добавляй свои команды через UI: !discord, !social, !price и любые другие">
      <span class="nav-icon">⌨️</span> Кастомные команды
    </div>
    <div class="nav-item" onclick="showTab('songs', this)"
      data-tip="Очередь реквестов от зрителей командой !sr [название]">
      <span class="nav-icon">🎵</span> Очередь реквестов
    </div>
    <div class="nav-item" onclick="showTab('vip', this)"
      data-tip="Список VIP-зрителей, выдача и отзыв VIP вручную">
      <span class="nav-icon">⭐</span> VIP зрители
    </div>
    <div class="nav-item" onclick="showTab('obs', this)"
      data-tip="Оверлеи для OBS: алерты, чат, цель, топ баллов и другие">
      <span class="nav-icon">🎬</span> OBS Оверлеи
    </div>
    <div class="nav-section">Игры</div>
    <div class="nav-item" onclick="showTab('trivia', this)"
      data-tip="Настройки викторины: свои вопросы, ответы, награды. !trivia запускает мод">
      <span class="nav-icon">🧠</span> Викторина
    </div>
    <div class="nav-section">Система</div>
    <div class="nav-item" onclick="showTab('features', this)"
      data-tip="Включить или выключить любую функцию бота по отдельности">
      <span class="nav-icon">⚙️</span> Функции (on/off)
    </div>
    <div class="nav-item" onclick="showTab('settings', this)"
      data-tip="Twitch OAuth токен, ник бота, название канала">
      <span class="nav-icon">🔑</span> Настройки бота
    </div>
    <div class="separator" style="margin-top: auto;"></div>
    <div class="nav-item" onclick="saveAllSettings()" style="margin-top:8px"
      data-tip="Сохранить все поля на текущей странице в базу данных">
      <span class="nav-icon">💾</span> Сохранить всё
    </div>
  </aside>

  <!-- MAIN -->
  <main class="main">

    <!-- DASHBOARD -->
    <div id="tab-dashboard" class="tab-content active">
      <div class="tab-desc">
        <div class="tab-desc-icon">📊</div>
        <div>
          <div class="tab-desc-title">Dashboard  -  обзор стрима</div>
          <div class="tab-desc-text">
            Главный экран: статистика в реальном времени, прогресс цели и топ зрителей по баллам.
            Используй кнопки <b>▶ СТАРТ</b> и <b>■ СТОП</b> вверху для управления стримом.
            Системный лог внизу показывает все события: фолловы, рейды, клипы, модерацию.
          </div>
        </div>
      </div>

      <div class="stats-grid">
        <div class="stat-card" data-tip="Время с момента нажатия СТАРТ. Обновляется каждую минуту.">
          <span class="stat-value" id="stat-uptime"> - </span>
          <div class="stat-label">Аптайм</div>
        </div>
        <div class="stat-card" data-tip="Всего сообщений в чате за всё время (из базы данных).">
          <span class="stat-value" id="stat-chatcount">0</span>
          <div class="stat-label">Сообщений за стрим</div>
        </div>
        <div class="stat-card" data-tip="Счётчик смертей стримера. Мод пишет !death в чат, или используй кнопку на вкладке Счётчики.">
          <span class="stat-value" id="stat-deaths" style="color:var(--red)">0</span>
          <div class="stat-label">Смертей 💀</div>
        </div>
        <div class="stat-card" data-tip="Количество созданных клипов за сессию.">
          <span class="stat-value" id="stat-clips">0</span>
          <div class="stat-label">Клипов</div>
        </div>
      </div>

      <div class="card">
        <div class="card-title">Прогресс цели</div>
        <div class="goal-section">
          <div class="goal-label-text" id="goal-label-display">Цель:  - </div>
          <div class="progress-bar"><div class="progress-fill" id="goal-progress" style="width:0%"></div></div>
          <div class="goal-numbers">
            <span id="goal-current-display">0</span>
            <span id="goal-pct-display">0%</span>
            <span id="goal-target-display">100</span>
          </div>
        </div>
        <div class="flex gap-8 mt-16">
          <input class="form-input" id="goal-inc" type="number" placeholder="+N" style="width:80px"
            title="Введи число и нажми + Добавить  -  текущее значение увеличится на это число">
          <button class="btn btn-primary btn-sm" onclick="incrementGoal()"
            data-tip="Увеличить текущее значение цели на указанное число">+ Добавить</button>
          <button class="btn btn-ghost btn-sm" onclick="showTab('obs', document.querySelector('[onclick*=overlays]'))"
            data-tip="Перейти к полным настройкам цели">⚙ Настроить</button>
        </div>
      </div>

      <div class="card">
        <div class="card-title">Топ-10 баллов</div>
        <table class="table">
          <thead><tr><th>#</th><th>Зритель</th><th>Баллы</th></tr></thead>
          <tbody id="top-points-body">
            <tr><td colspan="3" style="text-align:center;color:var(--text3);padding:20px">Нет данных</td></tr>
          </tbody>
        </table>
      </div>

      <div class="card">
        <div class="card-title">Системный лог</div>
        <div class="wslog" id="sys-log">Ожидание событий...<br></div>
      </div>
    </div>

    <!-- CHAT & COMMANDS -->
    <div id="tab-chat" class="tab-content">
      <div class="tab-desc">
        <div class="tab-desc-icon">💬</div>
        <div>
          <div class="tab-desc-title">Чат & Команды</div>
          <div class="tab-desc-text">
            Здесь можно <b>тестировать команды</b> без реального Twitch  -  симулируй сообщения от любого зрителя.
            Также можно вручную отправить любое сообщение в чат от имени бота.
            Полный список команд с описанием  -  в таблице ниже, или нажми <b>? ПОМОЩЬ</b> вверху для справочника с примерами.
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-title">Тест команд (без реального Twitch)</div>
        <div class="flex gap-8 mb-8">
          <input class="form-input" id="test-user" placeholder="username" style="width:140px" value="viewer1"
            title="Ник зрителя от имени которого отправляется сообщение">
          <input class="form-input" id="test-msg" placeholder="!points или любое сообщение"
            title="Команда или сообщение. Команды начинаются с !">
          <label class="flex items-center gap-8" style="font-size:11px;color:var(--text2);flex-shrink:0"
            title="Если включено  -  зритель считается модератором и может использовать мод-команды">
            <input type="checkbox" id="test-mod"> Мод
          </label>
          <button class="btn btn-primary btn-sm" onclick="testChat()"
            data-tip="Отправить тестовое сообщение  -  бот обработает его как настоящее">Отправить</button>
        </div>
        <div style="font-size:10px;color:var(--text3)">Попробуй: !points · !top · !daily · !sr [песня] · !trivia (запускает мод)</div>
      </div>

      <div class="card">
        <div class="card-title" style="display:flex;align-items:center;gap:8px">
          Список команд
          <button class="help-btn" onclick="openHelp()" title="Открыть справочник с примерами">?</button>
        </div>
        <table class="table">
