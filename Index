// ─── Manual warn ──────────────────────────────────────────────────────────────
async function addManualWarn() {
  var user = document.getElementById('warn-username').value.trim();
  var reason = document.getElementById('warn-reason').value.trim() || 'Ручной варн';
  if (!user) { notify('❌ Введи ник'); return; }
  var r = await fetch('/api/warnings/' + encodeURIComponent(user) + '/add?reason=' + encodeURIComponent(reason), {method:'POST'});
  var data = await r.json();
  document.getElementById('warn-result').textContent = '⚠️ ' + user + ' получил варн (' + data.warn_count + '/3)';
  sysLog('⚠️ Ручной варн: ' + user + ' (' + data.warn_count + '/3)');
  notify('⚠️ Варн выдан: ' + user);
}

// ─── VIP cost display sync ────────────────────────────────────────────────────
function syncVipCostDisplay(s) {
  var el = document.getElementById('vip-cost-display');
  if (el && s.vip_cost) el.textContent = s.vip_cost;
}

// ─── Extended showTab ─────────────────────────────────────────────────────────
